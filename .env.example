# =====================================================================
# certificacion_app — variables de entorno
# Copiar este archivo a `.env` y completar los valores.
# NUNCA commitear el `.env` real (ya esta en .gitignore).
# =====================================================================

# --- OpenAI (requerido para agente, vision y validacion LLM) ---
OPENAI_API_KEY=sk-...

# Proveedor LLM (por ahora solo "openai")
# LLM_PROVIDER=openai

# Modelos por funcion (todos opcionales; defaults entre parentesis)
# OPENAI_MODEL_AGENT=gpt-4o-mini            # asistente contable (gpt-4o-mini)
# OPENAI_MODEL_CHAT=gpt-4o-mini             # chat legacy (gpt-4o-mini)
# OPENAI_MODEL_DOCUMENTS=gpt-5-mini         # extraccion cedula/matricula (gpt-5-mini)
# OPENAI_MODEL_DOCUMENTS_FALLBACK=gpt-4o    # fallback si el anterior no esta disponible (gpt-4o)

# --- Servidor ---
# Host de escucha. Default 127.0.0.1 (solo esta maquina).
# Poner 0.0.0.0 SOLO si se necesita acceso desde otra maquina de la red
# (la app no tiene autenticacion y maneja datos personales).
# CERTAPP_HOST=127.0.0.1
# PORT=8000
# CERTAPP_DEBUG=0                           # 1 activa el modo debug de Flask
# CERTAPP_TEMPLATE_CACHE=0                  # 1 cachea templates/estaticos (produccion)

# --- Almacenamiento ---
# CERTAPP_DATABASE_URL=sqlite:///data/certificacion.db   # default: data/certificacion.db
# CERTAPP_MODEL_STORE_DIR=data/models       # drafts/finales del modelo (default: data/models)
# CERTAPP_DOCUMENTOS_DIR=data/documentos    # DOCX generados por periodo (default: data/documentos)
# CERTAPP_UPLOAD_DIR=                       # subidas temporales (default: temp del SO)
# CERTAPP_UPLOAD_TTL_SECONDS=7200           # limpieza de subidas (default: 2 horas)

# --- Base de datos ---
# CERTAPP_DB_REQUIRE_ALEMBIC=1              # 0 desactiva el chequeo de migraciones (solo dev)

# --- PDFs (opcional, solo si se suben cedulas/matriculas en PDF) ---
# Ruta a los binarios de Poppler en Windows, ej: C:\poppler-24.02.0\Library\bin
# POPPLER_PATH=
